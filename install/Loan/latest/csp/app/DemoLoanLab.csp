<html>
<head>
<meta charset="utf-8">
<title>Demo Loan Lab</title>
<style>
  :root {
    --paper: #fbf4eb;
    --ink: #1f2430;
    --muted: #6b7388;
    --accent: #8f3c2e;
    --accent-soft: #f3d0b0;
    --panel: rgba(24, 28, 40, 0.95);
    --ok: #0f8d5f;
    --warn: #d5862a;
    --error: #c84e40;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: "Segoe UI", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(circle at top right, rgba(143, 60, 46, 0.18), transparent 26%),
      linear-gradient(180deg, #fff9f1 0%, #eef2f5 100%);
  }

  .shell {
    max-width: 1240px;
    margin: 0 auto;
    padding: 24px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: 24px;
    padding: 30px;
    border-radius: 30px;
    color: #fff6ee;
    background: linear-gradient(135deg, rgba(111, 37, 27, 0.98), rgba(26, 31, 43, 0.96));
    box-shadow: 0 24px 60px rgba(45, 28, 24, 0.2);
  }

  .eyebrow, .panel-label {
    margin: 0 0 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1, h2, h3, h4, p { margin: 0; }

  .hero h1 {
    font-size: clamp(34px, 4vw, 58px);
    line-height: 0.95;
  }

  .hero p.copy {
    margin-top: 16px;
    line-height: 1.6;
    color: rgba(255, 246, 238, 0.82);
    max-width: 760px;
  }

  .hero-actions, .step-actions, .preset-row, .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-actions {
    justify-content: flex-end;
    align-content: start;
  }

  button {
    border: 0;
    border-radius: 999px;
    padding: 12px 18px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  button.primary {
    background: var(--accent-soft);
    color: #2b221a;
  }

  button.secondary {
    background: transparent;
    color: #fff6ee;
    border: 1px solid rgba(255, 246, 238, 0.28);
  }

  button.ghost {
    background: rgba(31, 36, 48, 0.06);
    color: var(--ink);
  }

  button:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .summary-grid,
  .steps-grid {
    display: grid;
    gap: 18px;
    margin-top: 20px;
  }

  .summary-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .panel,
  .step-card,
  .activity-card {
    border-radius: 24px;
    box-shadow: 0 12px 30px rgba(29, 34, 48, 0.08);
  }

  .panel,
  .activity-card {
    padding: 22px;
    background: rgba(255, 255, 255, 0.84);
  }

  .panel-detail,
  .step-card p,
  .activity-entry p {
    margin-top: 8px;
    color: var(--muted);
    line-height: 1.55;
  }

  .chip {
    display: inline-flex;
    margin-top: 12px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(87, 103, 130, 0.12);
    color: var(--muted);
    font-weight: 700;
  }

  .chip.ok { background: rgba(15, 141, 95, 0.16); color: var(--ok); }
  .chip.warn { background: rgba(143, 60, 46, 0.14); color: var(--accent); }

  .steps-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .step-card {
    display: grid;
    gap: 18px;
    padding: 22px;
    background: var(--paper);
  }

  .step-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    align-items: start;
  }

  .step-num {
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 18px;
    font-size: 22px;
    font-weight: 800;
    color: #342215;
    background: linear-gradient(135deg, #ffdabc, #efb07e);
  }

  .login-grid,
  .form-grid {
    display: grid;
    gap: 14px;
  }

  .login-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .form-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  label {
    display: grid;
    gap: 8px;
  }

  label span {
    font-size: 13px;
    font-weight: 700;
    color: #475165;
  }

  input {
    width: 100%;
    min-height: 46px;
    padding: 0 14px;
    border-radius: 14px;
    border: 1px solid rgba(31, 36, 48, 0.12);
    background: rgba(255, 255, 255, 0.95);
    color: var(--ink);
    font: inherit;
  }

  .result,
  .decision,
  .table-wrap,
  .trace-wrap {
    border-radius: 18px;
    overflow: hidden;
  }

  .result,
  .table-wrap,
  .trace-wrap {
    background: var(--panel);
    color: #f7f7f7;
  }

  .result-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 14px 16px 0;
  }

  .status-pill {
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.12);
  }

  .status-pill.ok { background: rgba(77, 213, 166, 0.18); color: #8cf2ca; }
  .status-pill.error { background: rgba(255, 120, 120, 0.16); color: #ffb4b4; }

  pre {
    margin: 0;
    padding: 16px;
    white-space: pre-wrap;
    overflow-x: auto;
    line-height: 1.55;
    font-size: 13px;
  }

  .decision {
    padding: 20px;
    background: rgba(255, 255, 255, 0.88);
  }

  .decision-top {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: center;
  }

  .decision-badge {
    margin: 0;
    padding: 8px 12px;
    border-radius: 999px;
    font-weight: 700;
    background: rgba(87, 103, 130, 0.12);
    color: var(--muted);
  }

  .decision-badge.ok { background: rgba(15, 141, 95, 0.14); color: var(--ok); }
  .decision-badge.warn { background: rgba(143, 60, 46, 0.14); color: var(--accent); }

  .decision-copy {
    margin-top: 10px;
    color: var(--muted);
    line-height: 1.55;
  }

  .metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .metrics div {
    padding: 14px;
    border-radius: 16px;
    background: rgba(31, 36, 48, 0.05);
  }

  .metrics span {
    display: block;
    color: var(--muted);
    font-size: 12px;
  }

  .metrics strong {
    display: block;
    margin-top: 6px;
    font-size: 18px;
  }

  .table-wrap {
    padding: 14px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 10px 12px;
    text-align: left;
  }

  thead th {
    color: #ffd9b9;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  tbody tr + tr {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .trace-wrap {
    padding: 12px;
  }

  .trace-item {
    padding: 12px 10px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
  }

  .trace-item + .trace-item {
    margin-top: 10px;
  }

  .trace-item .when {
    display: block;
    color: #f7c89d;
    font-size: 12px;
  }

  .trace-item p {
    margin-top: 4px;
    color: rgba(247, 247, 247, 0.84);
  }

  .activity-card {
    margin-top: 20px;
  }

  .activity-entry {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(31, 36, 48, 0.05);
  }

  .activity-entry + .activity-entry {
    margin-top: 12px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #9fb1c8;
    margin-top: 4px;
  }

  .dot.ok { background: var(--ok); }
  .dot.warn { background: var(--warn); }
  .dot.error { background: var(--error); }

  .activity-top {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
  }

  .muted {
    color: var(--muted);
  }

  @media (max-width: 1100px) {
    .hero,
    .summary-grid,
    .steps-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      justify-content: start;
    }
  }

  @media (max-width: 760px) {
    .shell {
      padding: 14px;
    }

    .hero,
    .panel,
    .step-card,
    .activity-card {
      border-radius: 20px;
    }

    .login-grid,
    .form-grid,
    .metrics,
    .result-head,
    .decision-top,
    .activity-top {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: start;
    }
  }
</style>
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div>
        <p class="eyebrow">Loan Mission Control</p>
        <h1>Prueba Loan sin salir de la pantalla</h1>
        <p class="copy">
          Esta p&aacute;gina obtiene un JWT, prepara la producci&oacute;n correcta, ejecuta los pasos clave del ejemplo Loan y muestra el resultado de cada llamada junto con la decisi&oacute;n final agregada del BPL.
        </p>
      </div>

      <div class="hero-actions">
        <button class="primary" id="loginButton">Conectar API</button>
        <button class="secondary" id="statusButton">Revisar estado</button>
        <button class="secondary" id="prepareButton">Preparar Demo.Loan</button>
      </div>
    </section>

    <section class="summary-grid">
      <article class="panel">
        <p class="panel-label">Credenciales API</p>
        <div class="login-grid">
          <label>
            <span>Usuario</span>
            <input id="username" value="superuser">
          </label>
          <label>
            <span>Password</span>
            <input id="password" type="password" value="SYS">
          </label>
          <label>
            <span>Estado</span>
            <input id="authState" value="sin token" readonly>
          </label>
        </div>
      </article>

      <article class="panel">
        <p class="panel-label">Solicitud actual</p>
        <h3 id="summaryName">Paula Vega</h3>
        <p class="panel-detail" id="summaryPayload">18000 USD - TaxID 19 - USA</p>
      </article>

      <article class="panel">
        <p class="panel-label">&Uacute;ltima decisi&oacute;n</p>
        <h3 id="summaryDecision">pendiente</h3>
        <p class="panel-detail" id="summaryDecisionDetail">Ejecuta la solicitud completa para ver el resultado agregado.</p>
      </article>
    </section>

    <section class="steps-grid">
      <article class="step-card">
        <div class="step-head">
          <div class="step-num">1</div>
          <div>
            <h3>Producci&oacute;n</h3>
            <p>Comprueba qu&eacute; producci&oacute;n est&aacute; activa y, si hace falta, detiene la actual para arrancar Demo.Loan.FindRateProduction.</p>
          </div>
        </div>

        <div class="step-actions">
          <button class="primary" id="stepStatusButton">Consultar estado</button>
          <button class="ghost" id="stepPrepareButton">Preparar Demo.Loan</button>
        </div>

        <div class="result">
          <div class="result-head">
            <strong>Estado de producci&oacute;n</strong>
            <span class="status-pill" id="productionStatusPill">sin ejecutar</span>
          </div>
          <pre id="productionResult">{}</pre>
        </div>
      </article>

      <article class="step-card">
        <div class="step-head">
          <div class="step-num">2</div>
          <div>
            <h3>Prime Rate</h3>
            <p>Prueba la operaci&oacute;n simulada que da la tasa base del ejemplo.</p>
          </div>
        </div>

        <div class="step-actions">
          <button class="primary" id="primeButton">Probar Prime Rate</button>
        </div>

        <div class="result">
          <div class="result-head">
            <strong>Prime Rate</strong>
            <span class="status-pill" id="primeStatusPill">sin ejecutar</span>
          </div>
          <pre id="primeResult">{}</pre>
        </div>
      </article>

      <article class="step-card">
        <div class="step-head">
          <div class="step-num">3</div>
          <div>
            <h3>Credit Rating</h3>
            <p>Calcula el rating del solicitante antes de disparar el flujo completo.</p>
          </div>
        </div>

        <div class="step-actions">
          <label style="min-width:220px;">
            <span>TaxID</span>
            <input id="taxId" value="19">
          </label>
          <button class="primary" id="creditButton">Calcular rating</button>
        </div>

        <div class="result">
          <div class="result-head">
            <strong>Credit Rating</strong>
            <span class="status-pill" id="creditStatusPill">sin ejecutar</span>
          </div>
          <pre id="creditResult">{}</pre>
        </div>
      </article>

      <article class="step-card">
        <div class="step-head">
          <div class="step-num">4</div>
          <div>
            <h3>Solicitud completa</h3>
            <p>Ejecuta el BPL real y devuelve la aprobaci&oacute;n consolidada, los bancos consultados y la traza de la sesi&oacute;n.</p>
          </div>
        </div>

        <div class="preset-row">
          <button class="ghost preset" data-amount="18000" data-name="Paula Vega" data-taxid="19" data-nationality="USA">Caso s&oacute;lido USA</button>
          <button class="ghost preset" data-amount="12000" data-name="Daniel Mora" data-taxid="13" data-nationality="USA">Rating bajo</button>
          <button class="ghost preset" data-amount="14000" data-name="Nora" data-taxid="17" data-nationality="Canada">Nombre impar</button>
        </div>

        <div class="form-grid">
          <label>
            <span>Monto</span>
            <input id="amount" value="18000">
          </label>
          <label>
            <span>Nombre</span>
            <input id="name" value="Paula Vega">
          </label>
          <label>
            <span>TaxID</span>
            <input id="appTaxId" value="19">
          </label>
          <label>
            <span>Nacionalidad</span>
            <input id="nationality" value="USA">
          </label>
        </div>

        <div class="step-actions">
          <button class="primary" id="applicationButton">Ejecutar solicitud</button>
        </div>

        <div class="result">
          <div class="result-head">
            <strong>Resultado crudo</strong>
            <span class="status-pill" id="applicationStatusPill">sin ejecutar</span>
          </div>
          <pre id="applicationResult">{}</pre>
        </div>

        <div class="decision" id="decisionPanel" style="display:none;">
          <div class="decision-top">
            <div>
              <p class="panel-label">Resultado agregado</p>
              <h4 id="decisionTitle">pendiente</h4>
            </div>
            <p class="decision-badge" id="decisionBadge">sin banco</p>
          </div>
          <p class="decision-copy" id="decisionCopy"></p>

          <div class="metrics">
            <div>
              <span>Record</span>
              <strong id="metricRecord">-</strong>
            </div>
            <div>
              <span>Session</span>
              <strong id="metricSession">-</strong>
            </div>
            <div>
              <span>Duraci&oacute;n</span>
              <strong id="metricDuration">-</strong>
            </div>
          </div>

          <div class="link-row" style="margin-top:16px;">
            <button class="ghost" id="messageViewerButton">Message Viewer</button>
            <button class="ghost" id="visualTraceButton">Visual Trace</button>
          </div>
        </div>

        <div class="table-wrap" id="bankReplyPanel" style="display:none;">
          <table>
            <thead>
              <tr>
                <th>Banco</th>
                <th>Aprueba</th>
                <th>Tasa</th>
                <th>Origen</th>
              </tr>
            </thead>
            <tbody id="bankReplyRows"></tbody>
          </table>
        </div>

        <div class="trace-wrap" id="tracePanel" style="display:none;">
          <div id="traceRows"></div>
        </div>
      </article>
    </section>

    <section class="activity-card">
      <p class="panel-label">Bit&aacute;cora</p>
      <h3>Qu&eacute; fue pasando</h3>
      <p class="muted" style="margin-top:8px;">Cada acci&oacute;n deja una entrada breve para narrar la demo sin abrir la consola.</p>
      <div id="activityLog" style="margin-top:18px;"></div>
    </section>
  </div>

<script>
(() => {
  const apiBase = '/order/api';
  let accessToken = '';
  let latestLinks = { messageViewerLink: '', visualTraceLink: '' };

  const qs = (id) => document.getElementById(id);
  const authState = qs('authState');
  const productionResult = qs('productionResult');
  const primeResult = qs('primeResult');
  const creditResult = qs('creditResult');
  const applicationResult = qs('applicationResult');
  const bankReplyRows = qs('bankReplyRows');
  const traceRows = qs('traceRows');
  const activityLog = qs('activityLog');

  function addActivity(title, detail, tone = 'neutral') {
    const entry = document.createElement('article');
    entry.className = 'activity-entry';
    entry.innerHTML = `
      <div class="dot ${tone === 'success' ? 'ok' : tone === 'warning' ? 'warn' : tone === 'error' ? 'error' : ''}"></div>
      <div>
        <div class="activity-top">
          <strong>${title}</strong>
          <span class="muted">${new Date().toLocaleTimeString()}</span>
        </div>
        <p>${detail}</p>
      </div>
    `;
    activityLog.prepend(entry);
  }

  function setStatus(id, status, ok) {
    const pill = qs(id);
    pill.textContent = status;
    pill.className = `status-pill ${ok ? 'ok' : status === 'sin ejecutar' ? '' : 'error'}`;
  }

  function pretty(node, value) {
    node.textContent = JSON.stringify(value ?? {}, null, 2);
  }

  function updateSummary() {
    const amount = qs('amount').value;
    const name = qs('name').value;
    const taxId = qs('appTaxId').value;
    const nationality = qs('nationality').value;
    qs('summaryName').textContent = name || 'sin nombre';
    qs('summaryPayload').textContent = `${amount || '-'} USD - TaxID ${taxId || '-'} - ${nationality || '-'}`;
    qs('taxId').value = taxId;
  }

  async function apiFetch(path, options = {}) {
    const headers = { 'Content-Type': 'application/json', ...(options.headers || {}) };
    if (accessToken) {
      headers.Authorization = `Bearer ${accessToken}`;
    }

    const response = await fetch(`${apiBase}${path}`, {
      ...options,
      headers
    });

    let body = {};
    try {
      body = await response.json();
    } catch (error) {
      body = { parseError: String(error) };
    }

    if (!response.ok) {
      throw { status: response.status, body };
    }

    return { status: response.status, body };
  }

  async function login() {
    const username = qs('username').value;
    const password = qs('password').value;
    const headers = {
      Authorization: `Basic ${btoa(`${username}:${password}`)}`
    };

    qs('loginButton').disabled = true;
    authState.value = 'conectando...';

    try {
      const response = await fetch(`${apiBase}/login`, {
        method: 'POST',
        headers
      });
      const body = await response.json();
      if (!response.ok) {
        throw { status: response.status, body };
      }
      accessToken = body.access_token || '';
      authState.value = accessToken ? 'token activo' : 'sin token';
      addActivity('API conectada', `Autenticacion JWT activa para ${username}.`, 'success');
    } catch (error) {
      authState.value = 'error';
      addActivity('No se pudo autenticar', JSON.stringify(error.body || error), 'error');
    } finally {
      qs('loginButton').disabled = false;
    }
  }

  async function loadProductionStatus() {
    setStatus('productionStatusPill', 'cargando...', false);
    try {
      const result = await apiFetch('/loan/production/status');
      pretty(productionResult, result.body);
      setStatus('productionStatusPill', `HTTP ${result.status}`, true);
      addActivity('Estado consultado', `La produccion activa es ${result.body.runningProduction || 'ninguna'}.`, result.body.matchesRequestedProduction ? 'success' : 'warning');
    } catch (error) {
      pretty(productionResult, error.body || error);
      setStatus('productionStatusPill', `HTTP ${error.status || 500}`, false);
      addActivity('Fallo el estado', JSON.stringify(error.body || error), 'error');
    }
  }

  async function prepareProduction() {
    setStatus('productionStatusPill', 'preparando...', false);
    try {
      const result = await apiFetch('/loan/production/prepare', { method: 'POST', body: '{}' });
      pretty(productionResult, result.body);
      setStatus('productionStatusPill', `HTTP ${result.status}`, true);
      const action = result.body.action || 'already-running';
      const detail = action === 'switched'
        ? `Se detuvo ${result.body.previousProduction || 'otra produccion'} y se arranco Demo.Loan.FindRateProduction.`
        : action === 'started'
          ? 'Demo.Loan.FindRateProduction se arranco desde cero.'
          : 'Demo.Loan.FindRateProduction ya estaba lista.';
      addActivity('Produccion preparada', detail, 'success');
    } catch (error) {
      pretty(productionResult, error.body || error);
      setStatus('productionStatusPill', `HTTP ${error.status || 500}`, false);
      addActivity('Fallo la preparacion', JSON.stringify(error.body || error), 'error');
    }
  }

  async function testPrimeRate() {
    setStatus('primeStatusPill', 'ejecutando...', false);
    try {
      const result = await apiFetch('/loan/prime-rate', { method: 'POST', body: '{}' });
      pretty(primeResult, result.body);
      setStatus('primeStatusPill', `HTTP ${result.status}`, true);
      addActivity('Prime Rate listo', `La demo devolvio ${result.body.primeRate} como tasa base.`, 'success');
    } catch (error) {
      pretty(primeResult, error.body || error);
      setStatus('primeStatusPill', `HTTP ${error.status || 500}`, false);
      addActivity('Fallo Prime Rate', JSON.stringify(error.body || error), 'error');
    }
  }

  async function testCreditRating() {
    setStatus('creditStatusPill', 'calculando...', false);
    try {
      const taxId = qs('taxId').value;
      qs('appTaxId').value = taxId;
      updateSummary();
      const result = await apiFetch('/loan/credit-rating', {
        method: 'POST',
        body: JSON.stringify({ taxId })
      });
      pretty(creditResult, result.body);
      setStatus('creditStatusPill', `HTTP ${result.status}`, true);
      addActivity('Credit Rating calculado', `Con TaxID ${taxId} el rating quedo en ${result.body.creditRating}.`, 'success');
    } catch (error) {
      pretty(creditResult, error.body || error);
      setStatus('creditStatusPill', `HTTP ${error.status || 500}`, false);
      addActivity('Fallo Credit Rating', JSON.stringify(error.body || error), 'error');
    }
  }

  function renderDecision(body) {
    const approval = body.approval || {};
    qs('decisionPanel').style.display = 'block';
    qs('decisionTitle').textContent = approval.isApproved ? 'Solicitud aprobada' : 'Solicitud no aprobada';
    qs('decisionBadge').textContent = approval.bankName || 'sin banco';
    qs('decisionBadge').className = `decision-badge ${approval.isApproved ? 'ok' : 'warn'}`;
    qs('decisionCopy').textContent = approval.text || '';
    qs('metricRecord').textContent = body.recordNumber || '-';
    qs('metricSession').textContent = body.session?.sessionId || '-';
    qs('metricDuration').textContent = `${body.durationSeconds || 0}s`;
    qs('summaryDecision').textContent = approval.bankName || 'sin banco';
    qs('summaryDecisionDetail').textContent = approval.isApproved
      ? `Aprobada con tasa ${approval.interestRate}%.`
      : 'No aprobada por el flujo agregado.';

    latestLinks = {
      messageViewerLink: body.session?.messageViewerLink || '',
      visualTraceLink: body.session?.visualTraceLink || ''
    };
  }

  function renderBankReplies(items) {
    bankReplyRows.innerHTML = '';
    qs('bankReplyPanel').style.display = items && items.length ? 'block' : 'none';
    (items || []).forEach((item) => {
      const row = document.createElement('tr');
      row.innerHTML = `
        <td>${item.bankName || ''}</td>
        <td>${item.isApproved ? 'Si' : 'No'}</td>
        <td>${item.interestRate || 'n/a'}</td>
        <td>${item.sourceConfigName || ''}</td>
      `;
      bankReplyRows.appendChild(row);
    });
  }

  function renderTrace(items) {
    traceRows.innerHTML = '';
    qs('tracePanel').style.display = items && items.length ? 'block' : 'none';
    (items || []).forEach((item) => {
      const entry = document.createElement('div');
      entry.className = 'trace-item';
      entry.innerHTML = `
        <span class="when">${item.timeLogged || ''}</span>
        <strong>${item.configName || ''}</strong>
        <p>${item.text || ''}</p>
      `;
      traceRows.appendChild(entry);
    });
  }

  async function runApplication() {
    setStatus('applicationStatusPill', 'ejecutando...', false);
    updateSummary();
    try {
      const payload = {
        amount: qs('amount').value,
        name: qs('name').value,
        taxId: qs('appTaxId').value,
        nationality: qs('nationality').value
      };
      qs('taxId').value = payload.taxId;
      const result = await apiFetch('/loan/application', {
        method: 'POST',
        body: JSON.stringify(payload)
      });
      pretty(applicationResult, result.body);
      setStatus('applicationStatusPill', `HTTP ${result.status}`, true);
      renderDecision(result.body);
      renderBankReplies(result.body.bankReplies);
      renderTrace(result.body.trace);
      addActivity('Solicitud ejecutada', `${result.body.approval?.bankName || 'sin banco'} respondio con ${result.body.approval?.interestRate || 'sin tasa'}%.`, result.body.approval?.isApproved ? 'success' : 'warning');
    } catch (error) {
      pretty(applicationResult, error.body || error);
      setStatus('applicationStatusPill', `HTTP ${error.status || 500}`, false);
      addActivity('Fallo la solicitud', JSON.stringify(error.body || error), 'error');
    }
  }

  function openLatest(kind) {
    const url = kind === 'trace' ? latestLinks.visualTraceLink : latestLinks.messageViewerLink;
    if (url) {
      window.open(url, '_blank', 'noopener');
    }
  }

  document.querySelectorAll('.preset').forEach((button) => {
    button.addEventListener('click', () => {
      qs('amount').value = button.dataset.amount || '';
      qs('name').value = button.dataset.name || '';
      qs('appTaxId').value = button.dataset.taxid || '';
      qs('taxId').value = button.dataset.taxid || '';
      qs('nationality').value = button.dataset.nationality || '';
      updateSummary();
      addActivity('Preset cargado', `${button.textContent.trim()} listo para ejecutarse.`, 'neutral');
    });
  });

  qs('loginButton').addEventListener('click', login);
  qs('statusButton').addEventListener('click', loadProductionStatus);
  qs('prepareButton').addEventListener('click', prepareProduction);
  qs('stepStatusButton').addEventListener('click', loadProductionStatus);
  qs('stepPrepareButton').addEventListener('click', prepareProduction);
  qs('primeButton').addEventListener('click', testPrimeRate);
  qs('creditButton').addEventListener('click', testCreditRating);
  qs('applicationButton').addEventListener('click', runApplication);
  qs('messageViewerButton').addEventListener('click', () => openLatest('viewer'));
  qs('visualTraceButton').addEventListener('click', () => openLatest('trace'));

  ['amount', 'name', 'appTaxId', 'nationality'].forEach((id) => {
    qs(id).addEventListener('input', updateSummary);
  });

  updateSummary();
})();
</script>
</body>
</html>
